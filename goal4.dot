digraph {
  rankdir = "LR"
  subgraph cluster_1 {
    label = "2-param"
    color = lightgrey
    rankdir = "LR"
    node [shape=plaintext];

    1 [label = <
      <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="4">
      <TR><TD COLSPAN="3">id (8 records)</TD></TR>
      <TR><TD PORT="TO_1">id</TD><TD BGCOLOR="black"></TD><TD PORT="FROM_1">integer</TD></TR>
      <TR><TD PORT="TO_2">param2</TD><TD></TD><TD PORT="FROM_2">numeric</TD></TR>
      </TABLE>>];
    2 [label = <
      <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="4">
      <TR><TD COLSPAN="3">distribution (2 records)</TD></TR>
      <TR><TD PORT="TO_1">distribution</TD><TD BGCOLOR="black"></TD><TD PORT="FROM_1">factor</TD></TR>
      </TABLE>>];
  }
  subgraph cluster_2 {
    label = "1+-param"
    color = lightgrey
    rankdir = "LR"
    node [shape=plaintext];

    3 [label = <
      <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="4">
      <TR><TD COLSPAN="3">id (14 records)</TD></TR>
      <TR><TD PORT="TO_1">id</TD><TD BGCOLOR="black"></TD><TD PORT="FROM_1">integer</TD></TR>
      <TR><TD PORT="TO_2">param1</TD><TD></TD><TD PORT="FROM_2">numeric</TD></TR>
      </TABLE>>];
    4 [label = <
      <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="4">
      <TR><TD COLSPAN="3">distribution (4 records)</TD></TR>
      <TR><TD PORT="TO_1">distribution</TD><TD BGCOLOR="black"></TD><TD PORT="FROM_1">factor</TD></TR>
      </TABLE>>];
  }
  subgraph cluster_3 {
    label = "random"
    color = lightgrey
    rankdir = "LR"
    node [shape=plaintext];

    5 [label = <
      <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="4">
      <TR><TD COLSPAN="3">id (21 records)</TD></TR>
      <TR><TD PORT="TO_1">id</TD><TD BGCOLOR="black"></TD><TD PORT="FROM_1">integer</TD></TR>
      <TR><TD PORT="TO_2">lower_bound</TD><TD></TD><TD PORT="FROM_2">numeric</TD></TR>
      <TR><TD PORT="TO_3">upper_bound</TD><TD></TD><TD PORT="FROM_3">numeric</TD></TR>
      <TR><TD PORT="TO_4">distribution</TD><TD></TD><TD PORT="FROM_4">factor</TD></TR>
      </TABLE>>];
    6 [label = <
      <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="4">
      <TR><TD COLSPAN="3">distribution (6 records)</TD></TR>
      <TR><TD PORT="TO_1">distribution</TD><TD BGCOLOR="black"></TD><TD PORT="FROM_1">factor</TD></TR>
      </TABLE>>];

    5:FROM_4 -> 6:TO_1;
  }
  subgraph cluster_4 {
    label = "fixed"
    color = lightgrey
    rankdir = "LR"
    node [shape=plaintext];

    7 [label = <
      <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="4">
      <TR><TD COLSPAN="3">id (3 records)</TD></TR>
      <TR><TD PORT="TO_1">id</TD><TD BGCOLOR="black"></TD><TD PORT="FROM_1">integer</TD></TR>
      <TR><TD PORT="TO_2">value</TD><TD></TD><TD PORT="FROM_2">numeric</TD></TR>
      </TABLE>>];
  }
  u [shape=circle];
  4:FROM_1 -> 6:TO_1;
  2:FROM_1 -> 4:TO_1;
  3:FROM_1 -> 5:TO_1;
  1:FROM_1 -> 3:TO_1;
  7:FROM_1 -> u [arrowhead="none", style=dashed];
  5:FROM_1 -> u [arrowhead="none", style=dashed];
}
